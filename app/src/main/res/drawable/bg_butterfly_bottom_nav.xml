<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#D2FFFFFF"
                android:centerColor="#DDFFFFFF"
                android:startColor="#E3FFFFFF"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#52000000" />
            <corners android:radius="30dp" />
        </shape>
    </item>
    <item
        android:left="8dp"
        android:right="8dp"
        android:top="1dp"
        android:bottom="38dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00000000"
                android:startColor="#1A000000"
                android:type="linear" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</layer-list>
