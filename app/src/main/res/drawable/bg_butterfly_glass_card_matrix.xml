<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#B0091714"
                android:centerColor="#CC0C1F1A"
                android:startColor="#DB113028"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#4F86F7D7" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="56dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#38E7FFF7"
                android:type="linear" />
            <corners android:radius="27dp" />
        </shape>
    </item>
</layer-list>
