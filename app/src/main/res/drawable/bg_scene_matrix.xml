<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#07120F"
                android:centerColor="#0A1E1A"
                android:startColor="#123128"
                android:type="linear" />
        </shape>
    </item>
    <item android:gravity="top">
        <inset android:insetTop="36dp">
            <shape android:shape="rectangle">
                <gradient
                    android:angle="0"
                    android:endColor="#0000FFC9"
                    android:centerColor="#1400FFC9"
                    android:startColor="#0000FFC9"
                    android:type="linear" />
                <size android:height="160dp" />
            </shape>
        </inset>
    </item>
    <item android:gravity="bottom">
        <inset android:insetBottom="18dp">
            <shape android:shape="rectangle">
                <gradient
                    android:angle="180"
                    android:endColor="#0000FFD1"
                    android:centerColor="#1100FFD1"
                    android:startColor="#0000FFD1"
                    android:type="linear" />
                <size android:height="120dp" />
            </shape>
        </inset>
    </item>
</layer-list>
