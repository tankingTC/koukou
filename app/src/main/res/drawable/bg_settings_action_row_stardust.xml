<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#6B0A111E"
                android:startColor="#8C132338"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#44DCF6FF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="24dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#20FFFFFF"
                android:type="linear" />
            <corners android:radius="19dp" />
        </shape>
    </item>
</layer-list>
