<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#8E0D1527"
                android:centerColor="#A7122037"
                android:startColor="#B5172944"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#40DCF6FF" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="34dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#22FFFFFF"
                android:type="linear" />
            <corners android:radius="21dp" />
        </shape>
    </item>
</layer-list>
