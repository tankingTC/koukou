<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#D50B1322"
                android:centerColor="#F0132440"
                android:startColor="#F91A2F4E"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#76E9FBFF" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    <item
        android:top="2dp"
        android:bottom="14dp">
        <shape android:shape="rectangle">
            <gradient
                android:centerX="50%"
                android:centerY="50%"
                android:centerColor="#34FFFFFF"
                android:endColor="#0000E6FF"
                android:gradientRadius="180dp"
                android:startColor="#1200E6FF"
                android:type="radial" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
