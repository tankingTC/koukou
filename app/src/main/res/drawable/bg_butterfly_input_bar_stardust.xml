<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#C00C1424"
                android:startColor="#DC14233B"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#58DDF7FF" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="20dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#24FFFFFF"
                android:type="linear" />
            <corners android:radius="25dp" />
        </shape>
    </item>
</layer-list>
