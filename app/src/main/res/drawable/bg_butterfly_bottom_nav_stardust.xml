<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#D20A101A"
                android:centerColor="#DD0E1729"
                android:startColor="#E5152641"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#58F6FBFF" />
            <corners android:radius="30dp" />
        </shape>
    </item>
    <item
        android:left="8dp"
        android:top="1dp"
        android:right="8dp"
        android:bottom="38dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#42FFFFFF"
                android:type="linear" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</layer-list>
