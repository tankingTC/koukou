<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#8A09111F"
                android:startColor="#B0142741"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#47D7F4FF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="18dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#26FFFFFF"
                android:type="linear" />
            <corners android:radius="23dp" />
        </shape>
    </item>
</layer-list>
