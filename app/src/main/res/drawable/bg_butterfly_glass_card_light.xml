<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#CFE0ECF5"
                android:centerColor="#DDF1F6FA"
                android:startColor="#F4FFFFFF"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#66C3D3E2" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="56dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#4DFFFFFF"
                android:type="linear" />
            <corners android:radius="27dp" />
        </shape>
    </item>
</layer-list>
