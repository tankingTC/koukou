<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp">

    <View
        android:id="@+id/dialog_halo"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="center"
        android:alpha="0.3"
        android:background="@drawable/bg_butterfly_halo" />

    <View
        android:id="@+id/dialog_sheen"
        android:layout_width="230dp"
        android:layout_height="96dp"
        android:layout_gravity="top|end"
        android:alpha="0.2"
        android:background="@drawable/bg_butterfly_sheen"
        android:rotation="-16" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_butterfly_glass_card"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="编辑资料"
            android:textColor="@color/butterfly_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_dialog_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="让你的信息与这片蝴蝶流光一样，更有辨识度。"
            android:textColor="@color/butterfly_text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/et_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_butterfly_input_bar"
            android:gravity="center_vertical"
            android:hint="请输入内容"
            android:minHeight="54dp"
            android:paddingHorizontal="18dp"
            android:paddingVertical="12dp"
            android:textColor="@color/butterfly_text_primary"
            android:textColorHint="@color/butterfly_text_muted"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:background="@drawable/bg_profile_btn_outline"
                android:gravity="center"
                android:minWidth="92dp"
                android:paddingHorizontal="18dp"
                android:text="取消"
                android:textColor="@color/butterfly_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btn_confirm"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_button_gradient_20"
                android:gravity="center"
                android:minWidth="92dp"
                android:paddingHorizontal="18dp"
                android:text="保存"
                android:textColor="@color/butterfly_pearl"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
