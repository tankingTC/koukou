<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_butterfly_scene">

    <com.example.koukou.widget.CodeRainView
        android:id="@+id/code_rain_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.82"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.example.koukou.widget.ThemeAtmosphereView
        android:id="@+id/theme_effect_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.92"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/glow_halo"
        android:layout_width="360dp"
        android:layout_height="360dp"
        android:alpha="0.18"
        android:background="@drawable/bg_butterfly_halo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/glow_sheen_top"
        android:layout_width="280dp"
        android:layout_height="108dp"
        android:alpha="0.14"
        android:background="@drawable/bg_butterfly_sheen"
        android:rotation="-18"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/iv_hero"
        android:layout_width="446dp"
        android:layout_height="384dp"
        android:layout_marginTop="-22dp"
        android:layout_marginEnd="-92dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <include layout="@layout/view_iridescent_butterfly" />
    </FrameLayout>

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/app_bar_height"
        android:paddingStart="@dimen/page_horizontal_padding"
        android:paddingEnd="@dimen/page_horizontal_padding"
        app:contentInsetStartWithNavigation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="@dimen/form_max_width">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="start|center_vertical"
            android:padding="12dp"
            android:rotation="180"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/butterfly_pearl" />
    </com.google.android.material.appbar.MaterialToolbar>

    <TextView
        android:id="@+id/tv_overline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_horizontal_padding"
        android:layout_marginTop="@dimen/space_xl"
        android:layout_marginEnd="@dimen/page_horizontal_padding"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.14"
        android:text="MORPHO ACCOUNT"
        android:textAllCaps="true"
        android:textColor="@color/butterfly_text_secondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintWidth_max="@dimen/form_max_width" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_horizontal_padding"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="@dimen/page_horizontal_padding"
        android:fontFamily="serif"
        android:lineSpacingExtra="-2sp"
        android:text="CREATE&#10;A NEW LIGHT"
        android:textColor="@color/butterfly_text_primary"
        android:textSize="36sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_overline"
        app:layout_constraintWidth_max="@dimen/form_max_width" />

    <TextView
        android:id="@+id/tv_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_horizontal_padding"
        android:layout_marginTop="@dimen/space_sm"
        android:layout_marginEnd="@dimen/page_horizontal_padding"
        android:text="设置昵称，生成专属扣扣号。"
        android:textColor="@color/butterfly_text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintWidth_max="@dimen/form_max_width" />

    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="@dimen/space_md"
        android:background="@drawable/bg_butterfly_panel"
        android:padding="14dp"
        android:src="@mipmap/tubiao"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_desc" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_form"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_horizontal_padding"
        android:layout_marginTop="@dimen/space_md"
        android:layout_marginEnd="@dimen/page_horizontal_padding"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_logo"
        app:layout_constraintWidth_max="@dimen/form_max_width"
        app:strokeColor="#30F3F6FC"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_butterfly_glass_card"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_account"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="昵称"
                app:boxBackgroundColor="#4D141A2E"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/butterfly_stroke"
                app:helperText="仅用于展示"
                app:helperTextTextColor="@color/butterfly_text_muted"
                app:hintTextColor="@color/butterfly_text_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_account"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:maxLines="1"
                    android:minHeight="@dimen/input_min_height"
                    android:textColor="@color/butterfly_text_primary"
                    android:textColorHint="@color/butterfly_text_muted" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_koukou_id"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:hint="扣扣号"
                app:boxBackgroundColor="#4D141A2E"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/butterfly_stroke"
                app:endIconDrawable="@android:drawable/ic_popup_sync"
                app:endIconMode="custom"
                app:endIconTint="@color/butterfly_text_secondary"
                app:helperText="支持手动输入 10 位号码"
                app:helperTextTextColor="@color/butterfly_text_muted"
                app:hintTextColor="@color/butterfly_text_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_koukou_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="10"
                    android:maxLines="1"
                    android:minHeight="@dimen/input_min_height"
                    android:textColor="@color/butterfly_text_primary"
                    android:textColorHint="@color/butterfly_text_muted" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_password"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:hint="密码"
                app:boxBackgroundColor="#4D141A2E"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/butterfly_stroke"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/butterfly_text_secondary"
                app:hintTextColor="@color/butterfly_text_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:minHeight="@dimen/input_min_height"
                    android:textColor="@color/butterfly_text_primary"
                    android:textColorHint="@color/butterfly_text_muted" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_confirm_password"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:hint="确认密码"
                app:boxBackgroundColor="#4D141A2E"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/butterfly_stroke"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/butterfly_text_secondary"
                app:hintTextColor="@color/butterfly_text_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:minHeight="@dimen/input_min_height"
                    android:textColor="@color/butterfly_text_primary"
                    android:textColorHint="@color/butterfly_text_muted" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@drawable/bg_button_gradient_28"
                android:text="注册账号"
                android:textColor="@color/butterfly_pearl"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="29dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
