<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_butterfly_scene">

    <com.example.koukou.widget.CodeRainView
        android:id="@+id/code_rain_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.82"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.example.koukou.widget.ThemeAtmosphereView
        android:id="@+id/theme_effect_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.92"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/glow_halo"
        android:layout_width="360dp"
        android:layout_height="360dp"
        android:alpha="0.22"
        android:background="@drawable/bg_butterfly_halo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/glow_sheen_top"
        android:layout_width="300dp"
        android:layout_height="120dp"
        android:alpha="0.18"
        android:background="@drawable/bg_butterfly_sheen"
        android:rotation="-24"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/glow_sheen_bottom"
        android:layout_width="240dp"
        android:layout_height="96dp"
        android:alpha="0.12"
        android:background="@drawable/bg_butterfly_sheen"
        android:rotation="22"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <FrameLayout
        android:id="@+id/iv_hero"
        android:layout_width="452dp"
        android:layout_height="388dp"
        android:layout_marginTop="-24dp"
        android:layout_marginEnd="-96dp"
        android:alpha="0.98"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <include layout="@layout/view_iridescent_butterfly" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_overline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_horizontal_padding"
        android:layout_marginTop="@dimen/space_xl"
        android:layout_marginEnd="@dimen/page_horizontal_padding"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.14"
        android:text="NATURE INSPIRED UI"
        android:textAllCaps="true"
        android:textColor="@color/butterfly_text_secondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="@dimen/form_max_width" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_horizontal_padding"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="@dimen/page_horizontal_padding"
        android:fontFamily="serif"
        android:lineSpacingExtra="-2sp"
        android:maxLines="2"
        android:text="BUTTERFLY&#10;IRIDESCENCE"
        android:textColor="@color/butterfly_text_primary"
        android:textSize="38sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_overline"
        app:layout_constraintWidth_max="@dimen/form_max_width" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_horizontal_padding"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="@dimen/page_horizontal_padding"
        android:text="Light is alive. 使用扣扣号快速登录，回到流光蝶翼般的会话世界。"
        android:textColor="@color/butterfly_text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintWidth_max="@dimen/form_max_width" />

    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_marginTop="@dimen/space_md"
        android:alpha="0.0"
        android:background="@drawable/bg_butterfly_panel"
        android:padding="14dp"
        android:scaleX="0.8"
        android:scaleY="0.8"
        android:src="@mipmap/tubiao"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.15"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_form"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_horizontal_padding"
        android:layout_marginTop="@dimen/space_md"
        android:layout_marginEnd="@dimen/page_horizontal_padding"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_logo"
        app:layout_constraintWidth_max="@dimen/form_max_width"
        app:strokeColor="#6C96DFFF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_butterfly_glass_card"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="快捷登录"
                android:textColor="@color/butterfly_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="通过扣扣号和已保存密码快速进入"
                android:textColor="@color/butterfly_text_muted"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_account"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:hint="扣扣号"
                app:boxBackgroundColor="#9C152443"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/butterfly_stroke"
                app:endIconDrawable="@android:drawable/arrow_down_float"
                app:endIconMode="custom"
                app:endIconTint="@color/butterfly_text_secondary"
                app:hintTextColor="@color/butterfly_text_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_account"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1"
                    android:minHeight="@dimen/input_min_height"
                    android:textColor="@color/butterfly_text_primary"
                    android:textColorHint="@color/butterfly_text_muted" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_password"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:hint="密码"
                app:boxBackgroundColor="#9C152443"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/butterfly_stroke"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/butterfly_text_secondary"
                app:hintTextColor="@color/butterfly_text_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:minHeight="@dimen/input_min_height"
                    android:textColor="@color/butterfly_text_primary"
                    android:textColorHint="@color/butterfly_text_muted" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/fl_login"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_horizontal_padding"
        android:layout_marginTop="@dimen/space_lg"
        android:layout_marginEnd="@dimen/page_horizontal_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cv_form"
        app:layout_constraintWidth_max="@dimen/form_max_width">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/bg_button_gradient_28"
            android:text="登录"
            android:textColor="@color/butterfly_pearl"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="29dp" />

        <ProgressBar
            android:id="@+id/pb_loading"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:elevation="10dp"
            android:indeterminateTint="@color/butterfly_pearl"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_register"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:paddingHorizontal="@dimen/space_md"
        android:paddingVertical="10dp"
        android:text="没有账号？点击注册"
        android:textColor="@color/butterfly_text_secondary"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fl_login" />

    <include
        android:id="@+id/layout_history"
        layout="@layout/layout_account_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/iv_logo" />

</androidx.constraintlayout.widget.ConstraintLayout>
