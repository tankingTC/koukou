<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chat_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_butterfly_scene">

    <com.example.koukou.widget.CodeRainView
        android:id="@+id/code_rain_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.8"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.example.koukou.widget.ThemeAtmosphereView
        android:id="@+id/theme_effect_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.9"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/iv_hero"
        android:layout_width="392dp"
        android:layout_height="332dp"
        android:layout_marginTop="-18dp"
        android:layout_marginEnd="-76dp"
        android:alpha="0.78"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <include layout="@layout/view_iridescent_butterfly" />
    </FrameLayout>

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/app_bar_height"
        android:paddingStart="@dimen/page_horizontal_padding"
        android:paddingEnd="@dimen/page_horizontal_padding"
        app:contentInsetStartWithNavigation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="@dimen/content_max_width"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:titleTextColor="@color/butterfly_text_primary"
        tools:title="Rainbow Whisper" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/page_horizontal_padding"
        android:paddingTop="@dimen/space_sm"
        android:paddingEnd="@dimen/page_horizontal_padding"
        android:paddingBottom="@dimen/space_sm"
        app:layout_constraintBottom_toTopOf="@id/layout_bottom_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintWidth_max="@dimen/content_max_width" />

    <LinearLayout
        android:id="@+id/layout_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/page_horizontal_padding"
        android:paddingEnd="@dimen/page_horizontal_padding"
        android:paddingBottom="@dimen/space_md"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_max="@dimen/content_max_width">

        <LinearLayout
            android:id="@+id/layout_function_bar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="@dimen/space_sm"
                android:padding="8dp"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="@color/butterfly_text_secondary" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="@dimen/space_sm"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="@color/butterfly_text_secondary" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="@dimen/space_sm"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="@color/butterfly_text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_butterfly_input_bar"
            android:elevation="0dp"
            android:gravity="center_vertical"
            android:minHeight="@dimen/bottom_input_min_height"
            android:orientation="horizontal"
            android:padding="8dp">

            <EditText
                android:id="@+id/et_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:gravity="top|start"
                android:hint="输入消息..."
                android:maxLines="5"
                android:minHeight="@dimen/input_min_height"
                android:paddingStart="@dimen/input_horizontal_padding"
                android:paddingTop="12dp"
                android:paddingEnd="@dimen/input_horizontal_padding"
                android:paddingBottom="12dp"
                android:textColor="@color/butterfly_text_primary"
                android:textColorHint="@color/butterfly_text_muted"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/btn_more"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="@dimen/space_sm"
                android:contentDescription="更多"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_add"
                app:tint="@color/butterfly_text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_send"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/bg_button_gradient_20"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@null"
                app:cornerRadius="20dp"
                app:icon="@android:drawable/ic_menu_send"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/layout_emoji_panel"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginTop="@dimen/space_sm"
            android:background="@drawable/bg_butterfly_panel"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_emojis"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="@dimen/space_sm" />
        </FrameLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
